<Application x:Class="StationeersScreensDesigner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StationeersScreensDesigner"
             >
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundMain" Color="#1A1C24"/>
        <SolidColorBrush x:Key="BackgroundPanel" Color="#232732"/>
        <SolidColorBrush x:Key="BackgroundCanvas" Color="#1E3A5F"/>

        <SolidColorBrush x:Key="AccentCyber" Color="#00F2FF"/>
        <SolidColorBrush x:Key="AccentAction" Color="#3A86FF"/>
        <SolidColorBrush x:Key="AccentPanel" Color="#FF00A2"/>

        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#4A4F5D"/>

        <LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2E39" Offset="0.0" />
            <GradientStop Color="#1A1C24" Offset="1.0" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ActionGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3A86FF" Offset="0.0" />
            <GradientStop Color="#00F2FF" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InsetGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#12141A" Offset="0.0" />
            <GradientStop Color="#1E222D" Offset="0.5" />
            <GradientStop Color="#2A2E39" Offset="1.0" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="InsetCornerGlow"
            Center="1,1" GradientOrigin="1,1" 
                             RadiusX="0.6" RadiusY="0.6">
            <GradientStop Color="#A0E3" Offset="0" />

            <GradientStop Color="#30A0FFE3" Offset="0.4" />

            <GradientStop Color="#FF232732" Offset="0.9" />

            <GradientStop Color="#FF232732" Offset="1" />
        </RadialGradientBrush>
    </Application.Resources>
</Application>
