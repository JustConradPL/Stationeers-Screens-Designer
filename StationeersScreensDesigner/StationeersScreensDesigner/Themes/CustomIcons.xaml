<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="IconSaveGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3A86FF" Offset="0.0"/>
        <GradientStop Color="#FF0044FF" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="IconFolderBase" Color="#FF8892B0"/>
    <SolidColorBrush x:Key="IconFolderAccent" Color="#FF00F2FF"/>

    <DrawingImage x:Key="CloseDrawing">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Thickness="1" Brush="{StaticResource IconSaveGradient}"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0"
                                          EndPoint="25,25"
                                          />
                            <LineGeometry StartPoint="25,0"
                                          EndPoint="0,25"
                                          />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="IconSaveDrawing">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Thickness="1" Brush="{StaticResource IconSaveGradient}"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="
                                      M5,0 
                                      H20
                                      L25,5
                                      V20
                                      A4,4,0,0,1,20,25
                                      H5
                                      A4,4,0,0,1,0,20
                                      V5
                                      A4,4,0,0,1,5,0
                                      "/>
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Thickness="1" Brush="{StaticResource IconSaveGradient}"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M6,0
                                      V8
                                      A2,2,0,0,0,8,9
                                      H16
                                      A2,2,0,0,0,18,7
                                      V0
                                      Z"/>
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Thickness="1" Brush="{StaticResource IconSaveGradient}"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M18,25 
                                      V17
                                      A2,2,0,0,0,16,15
                                      H8
                                      A2,2,0,0,0,6,17
                                      V25
                                      "/>
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>


            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    
</ResourceDictionary>