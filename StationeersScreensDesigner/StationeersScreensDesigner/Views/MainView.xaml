<Window x:Class="StationeersScreensDesigner.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StationeersScreensDesigner.Views"
        xmlns:bh="clr-namespace:StationeersScreensDesigner.Behaviours"
        xmlns:vm="clr-namespace:StationeersScreensDesigner.ViewModels"
        xmlns:mod="clr-namespace:StationeersScreensDesigner.Models"
        xmlns:conv="clr-namespace:StationeersScreensDesigner.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:beh="clr-namespace:CodeParagon.Behaviors;assembly=CodeParagon.Behaviors"
        xmlns:sel="clr-namespace:StationeersScreensDesigner.Selectors"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Designer" Height="800" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundMain}"
        >
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Key="F2" Command="{Binding ChangeScreenNameCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding CurrentScreen.DuplicateSelectedCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <ResourceDictionary>

            <Style x:Key="BrowserTabStyle" TargetType="ListBoxItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="TabBorder" 
                                    Background="#1A1A1A" 
                                    BorderBrush="{StaticResource SeparatorBrush}" 
                                    BorderThickness="1,1,1,0" 
                                    CornerRadius="5,5,0,0" 
                                    Margin="2,0" 
                                    Padding="15,5">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseEnter">
                                        <i:ChangePropertyAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                PropertyName="HoveredScreen"
                                                                Value="{Binding}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:ChangePropertyAction TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                PropertyName="HoveredScreen"
                                                                Value="{x:Null}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>


                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#2A2A2A"/>
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="White"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <SolidColorBrush x:Key="blackish" Color="#1e1e24"/>

            <conv:SubtypeToStringConverter x:Key="SubtypeToString"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <conv:MultiValueConverter x:Key="MultiBinding"/>
            <conv:MouseWheelZoomConverter x:Key="MouseWheelZoom"/>
            <Border x:Key="MyFollowerVisual" 
                    Width="60" Height="60" 
                    Background="#804A90E2" 
                    BorderBrush="White" BorderThickness="2" 
                    CornerRadius="30" IsHitTestVisible="False"
                    >
                <TextBlock Text="🚀" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
            </Border>

            <Style x:Key="ToolboxGroup" TargetType="Expander">
                <Setter Property="FontSize" Value="32"/>
                <Setter Property="IsExpanded" Value="False"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="DemiBold"/>
                <Setter Property="HeaderTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding}"/>
                                <Rectangle Height="1"
                                       Fill="White"
                                       Margin="0,2,0,0" 
                                       HorizontalAlignment="Stretch"
                                       />
                            </StackPanel>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/CustomIcons.xaml"/>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
                <ResourceDictionary Source="/Themes/PropertyEditor.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <i:Interaction.Triggers>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="520"/>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!--Top Section-->
        <Border Grid.ColumnSpan="100"
                Background="{StaticResource PanelGradient}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="1">
            <Grid>
                <Rectangle
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Fill="#BA1BBB"
                    Opacity="0.1"
             >
                    <Rectangle.Effect>
                        <BlurEffect Radius="70" KernelType="Box" RenderingBias="Quality"/>
                    </Rectangle.Effect>

                </Rectangle>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!--Save Button-->
                    <StackPanel>
                        <Button Width="25" Height="25"
                            BorderThickness="0"
                            Focusable="False"
                            Cursor="Hand"
                                Command="{Binding SaveProjectCommand}"
                                >
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource IconSaveDrawing}"/>
                            </Button.Background>
                        </Button>
                        <TextBlock Text="SAVE"
                                   FontFamily="Simplex"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12"/>
                    </StackPanel>

                    <!--spacing-->
                    <Border Width="15"/>

                    <!--Open Button-->
                    <StackPanel>
                        <Button Width="25" Height="25"
                            BorderThickness="0"
                            Focusable="False"
                            Cursor="Hand"
                                Command="{Binding LoadProjectCommand}"
                                >
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource IconSaveDrawing}"/>
                            </Button.Background>
                        </Button>
                        <TextBlock Text="OPEN"
                                   FontFamily="Simplex"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12"/>
                    </StackPanel>
                    <!--Spacing-->
                    <Border Width="15"/>

                    <!--Close Button-->
                    <StackPanel>
                        <Button Width="25" Height="25"
                            BorderThickness="0"
                            Focusable="False"
                            Cursor="Hand"
                                >
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource CloseDrawing}"/>
                            </Button.Background>
                            <i:Interaction.Behaviors>
                                <beh:CloseWindowOnClickBehavior/>
                            </i:Interaction.Behaviors>
                        </Button>
                        <TextBlock Text="Close"
                                   FontFamily="Simplex"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="12"/>
                    </StackPanel>

                </StackPanel>


            </Grid>


        </Border>
        <!--ToolBox with UI elements-->
        <Border Grid.Row="2"
                Grid.Column="1"
                Background="{StaticResource BackgroundPanel}"
                CornerRadius="8"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="2">
            <StackPanel>
                <TextBlock Text="ELEMENT LIBRARY"
                           Foreground="{StaticResource TextPrimary}"
                           Opacity="0.6"
                           FontFamily="Complex" 
                       >
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3"
                                          Direction="300"
                                          Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Separator Background="{StaticResource SeparatorBrush}"/>
                <ItemsControl
            ItemsSource="{Binding AvailableElements}"
            >
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="mod:LuaUIElement">
                            <DataTemplate.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Light"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="16"/>
                                </Style>
                            </DataTemplate.Resources>
                            <StackPanel>
                                <Border BorderBrush="White" 
                            BorderThickness="2" 
                            HorizontalAlignment="Left" 
                            CornerRadius="2"
                            Margin="10,10,0,0"
                                        >
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.StartDragCommand,RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   >
                                                <i:InvokeCommandAction.CommandParameter>
                                                    <MultiBinding Converter="{StaticResource MultiBinding}">
                                                        <Binding Path="."/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                    </MultiBinding>
                                                </i:InvokeCommandAction.CommandParameter>
                                            </i:InvokeCommandAction>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <StackPanel Orientation="Horizontal" >
                                        <TextBlock Text="{Binding Converter={StaticResource SubtypeToString},StringFormat='◈ {0}'}"/>
                                    </StackPanel>
                                </Border>
                                <Separator/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!--Designer View-->
        <Border Grid.Row="2"
                Grid.Column="2"
                Background="{StaticResource BackgroundPanel}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="2"
                CornerRadius="8"
                HorizontalAlignment="Right"
                Width="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
               Text="LIVE CANVAS"
               Foreground="{StaticResource TextPrimary}"
               Opacity="0.6"
               FontFamily="Complex">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3" Direction="300" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <TextBlock Grid.Row="0" 
               Text="{Binding CurrentScreen.ZoomLevel, StringFormat='ZOOM LEVEL: {0:0%}'}"
               Foreground="{StaticResource TextPrimary}"
               Opacity="0.6"
               FontFamily="Complex"
                           HorizontalAlignment="Right">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3" Direction="300" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <Separator Grid.Row="1" Background="{StaticResource SeparatorBrush}"/>

                <Grid Grid.Row="2">
                    <!--<Border Background="{StaticResource BlueprintGridThick}" Panel.ZIndex="2" IsHitTestVisible="False"/>
                    <Border Background="{StaticResource BlueprintGridThin}" Panel.ZIndex="2" IsHitTestVisible="False"/>-->

                    <ScrollViewer Panel.ZIndex="3"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource StationeersScrollBar}"/>
                        </ScrollViewer.Resources>
                        <i:Interaction.Behaviors>
                            <bh:DesignerScrollBehaviour ZoomCommand="{Binding CurrentScreen.ZoomCommand}"/>
                        </i:Interaction.Behaviors>
                        <ItemsControl ItemsSource="{Binding CurrentScreen.CanvasElements}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Width="2000" Height="2000">

                            <ItemsControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding CurrentScreen.ZoomLevel}" ScaleY="{Binding CurrentScreen.ZoomLevel}"/>
                            </ItemsControl.LayoutTransform>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas AllowDrop="True" Background="{StaticResource MasterBlueprintGrid}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Drop">
                                                <i:InvokeCommandAction Command="{Binding StopDragCommand}" 
                                                           PassEventArgsToCommand="True"/>
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="MouseDown">
                                                <i:InvokeCommandAction Command="{Binding DeselectElementsCommand}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Canvas>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                                    <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.Resources>
                                <ResourceDictionary>
                                    <ResourceDictionary.MergedDictionaries>
                                        <ResourceDictionary Source="/Themes/DisplayLuaElements.xaml"/>
                                    </ResourceDictionary.MergedDictionaries>
                                </ResourceDictionary>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!--Properties-->
        <Border Grid.Row="2"
                Grid.Column="3"
                Background="{StaticResource BackgroundPanel}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="2"
                CornerRadius="8"
                HorizontalAlignment="Right"
                Width="300">
            <StackPanel>
                <TextBlock Text="PROPERTIES"
               Foreground="{StaticResource TextPrimary}"
               Opacity="0.6"
               FontFamily="Complex" 
                >
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3"
                  Direction="300"
                  Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Separator Background="{StaticResource SeparatorBrush}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Height="600">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource StationeersScrollBar2}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding ActiveProperties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,10">
                                    <TextBlock Text="{Binding GroupName}" Opacity="0.8" FontSize="16" 
                                               Foreground="White" />

                                    <ItemsControl ItemsSource="{Binding Properties}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="140" Margin="2">
                                                    <TextBlock Text="{Binding DisplayName}" Opacity="0.8" FontSize="12"
                                                               Foreground="White"/>
                                                    <ContentControl Content="{Binding}" 
                                ContentTemplateSelector="{StaticResource MyPropertySelector}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!--Lua Viewer-->
        <Border Grid.Row="2"
                Grid.Column="4"
                Background="{StaticResource BackgroundPanel}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="2"
                CornerRadius="8"
                HorizontalAlignment="Right"
                Width="370"
                ClipToBounds="True">
            <Grid Width="370">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="9*"/>
                    <ColumnDefinition Width="361*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
               Text="LUA CODE OUTPUT"
               Foreground="{StaticResource TextPrimary}"
               Opacity="0.6"
               FontFamily="Complex"
               Margin="5,2,5,2" Grid.ColumnSpan="2">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3" Direction="300" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Separator Grid.Row="1" Background="{StaticResource SeparatorBrush}" Margin="0,2,0,2" Grid.ColumnSpan="2"/>

                <ScrollViewer Grid.Row="1"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="#0F111A"
                  Height="605"
                  Width="365"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="0,5,0,-11" Grid.RowSpan="2">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource StationeersScrollBar2}"/>
                    </ScrollViewer.Resources>

                    <Grid Margin="5" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                       Text="{Binding LineNumbers}"
                       Foreground="#444"
                       FontFamily="Consolas"
                       FontSize="13"
                       LineHeight="20" 
                       TextAlignment="Right"
                       Margin="0,0,10,0"/>

                        <TextBox Grid.Column="1"
                     Text="{Binding GeneratedLuaCode, Mode=OneWay}"
                     Foreground="#A6ACCD"
                     Background="Transparent"
                     BorderThickness="0"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap" 
                     FontFamily="Consolas" 
                     FontSize="13"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!--Bottom Section-->
        <Border Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" 
                Background="#111" 
                BorderBrush="{StaticResource SeparatorBrush}" 
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <ListBox ItemsSource="{Binding Screens}" 
                         SelectedItem="{Binding CurrentScreen}" 
                         ItemContainerStyle="{StaticResource BrowserTabStyle}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Name}" 
                       Foreground="White" 
                       FontSize="12" 
                       VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"
                                         MinWidth="50"
                                         Background="#444"
                                         Foreground="White"
                                         BorderThickness="1"
                                         BorderBrush="#BA1BBB"
                                        >
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>

                                    <i:Interaction.Behaviors>
                                        <bh:TextBoxRenameBehavior CommitCommand="{Binding CommitEditCommand}" 
                                              CancelCommand="{Binding CancelEditCommand}"/>
                                    </i:Interaction.Behaviors>
                                </TextBox>
                            </Grid>
                        </DataTemplate>

                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Command="{Binding AddScreenCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Foreground="White" 
                        Content="+" 
                        FontSize="18" 
                        Width="30" Height="30" 
                        Margin="5,0,0,5" 
                        Cursor="Hand"
                        VerticalAlignment="Bottom">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#BA1BBB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
        <!--Accent-->
        <Grid Grid.ColumnSpan="1000"
              Grid.RowSpan="1000"
              IsHitTestVisible="False">
            <Grid.CacheMode>
                <BitmapCache EnableClearType="True"
                             RenderAtScale="1"
                             SnapsToDevicePixels="True"/>
            </Grid.CacheMode>
            <Ellipse Width="600" Height="600" 
                 Fill="#FF007F" 
                 HorizontalAlignment="Right" 
                 VerticalAlignment="Bottom" 
                 Margin="0,0,270,-250" 
                 Opacity="0.03"
                 Grid.Column="3"
                 Grid.Row="2"
                 Grid.RowSpan="10"
                 Grid.ColumnSpan="10">
                <Ellipse.Effect>
                    <BlurEffect Radius="140" KernelType="Gaussian" RenderingBias="Quality" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300"
                     Height="300" 
                     Fill="#FF007F" 
                     HorizontalAlignment="Center" 
                     VerticalAlignment="Top" 
                     Margin="0,0,0,0" 
                     Opacity="0.03"
                     Grid.Column="3"
                     Grid.Row="2"
                     Grid.RowSpan="10"
                     Grid.ColumnSpan="10">
                <Ellipse.Effect>
                    <BlurEffect Radius="140" KernelType="Gaussian" RenderingBias="Quality" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="1500" Height="1500" 
         Fill="#FF006A" 
         HorizontalAlignment="Center" 
         VerticalAlignment="Center" 
         Margin="0,0,0,0" 
         Opacity="0.02"
         Grid.Column="0"
         Grid.Row="0"
         Grid.RowSpan="10"
         Grid.ColumnSpan="10"
         Panel.ZIndex="-1">
                <Ellipse.Effect>
                    <BlurEffect Radius="140" KernelType="Gaussian" RenderingBias="Quality" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
    </Grid>
</Window>