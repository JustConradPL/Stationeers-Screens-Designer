<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="IconSaveGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0.0" Color="#FF3A86FF" />
        <GradientStop Offset="1.0" Color="#FF0044FF" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="IconFolderBase" Color="#FF8892B0" />
    <SolidColorBrush x:Key="IconFolderAccent" Color="#FF00F2FF" />
    <DrawingImage x:Key="CopyDrawing">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconSaveGradient}" Thickness="3" />
                    </GeometryDrawing.Pen>

                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!--  1. The Main Board Outline  -->
                            <!--  M = Move, L = Line, A = Arc (for rounded corners)  -->
                            <PathGeometry Figures="M 18,10 L 82,10 A 8,8 0 0 1 90,18 L 90,102 A 8,8 0 0 1 82,110 L 18,110 A 8,8 0 0 1 10,102 L 10,18 A 8,8 0 0 1 18,10 Z" />

                            <!--  2. The Paper Outline  -->
                            <RectangleGeometry Rect="20,25,60,75" />

                            <!--  3. The Metal Clip Outline  -->
                            <PathGeometry Figures="M 35,25 L 35,18 C 35,12 40,8 50,8 C 60,8 65,12 65,18 L 65,25 M 30,25 L 70,25" />

                            <!--  4. The Hanging Ring Outline  -->
                            <PathGeometry Figures="M 45,8 A 5,5 0 1 1 55,8" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="CloseDrawing">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconSaveGradient}" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="25,25" />
                            <LineGeometry StartPoint="25,0" EndPoint="0,25" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="IconSaveDrawing">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconSaveGradient}" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="                                       M5,0                                        H20                                       L25,5                                       V20                                       A4,4,0,0,1,20,25                                       H5                                       A4,4,0,0,1,0,20                                       V5                                       A4,4,0,0,1,5,0                                       " />
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconSaveGradient}" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M6,0                                       V8                                       A2,2,0,0,0,8,9                                       H16                                       A2,2,0,0,0,18,7                                       V0                                       Z" />
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconSaveGradient}" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M18,25                                        V17                                       A2,2,0,0,0,16,15                                       H8                                       A2,2,0,0,0,6,17                                       V25                                       " />
                    </GeometryDrawing.Geometry>

                </GeometryDrawing>


            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>


</ResourceDictionary>