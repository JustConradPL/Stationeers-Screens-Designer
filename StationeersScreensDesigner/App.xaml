<Application
    x:Class="StationeersScreensDesigner.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:StationeersScreensDesigner">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundMain" Color="#1A1C24" />
        <SolidColorBrush x:Key="BackgroundPanel" Color="#232732" />
        <SolidColorBrush x:Key="BackgroundCanvas" Color="#1E3A5F" />

        <SolidColorBrush x:Key="AccentCyber" Color="#00F2FF" />
        <SolidColorBrush x:Key="AccentAction" Color="#3A86FF" />
        <SolidColorBrush x:Key="AccentPanel" Color="#FF00A2" />

        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#E0E0E0" />
        <SolidColorBrush x:Key="SeparatorBrush" Color="#4A4F5D" />

        <LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0.0" Color="#2A2E39" />
            <GradientStop Offset="1.0" Color="#1A1C24" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ActionGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#3A86FF" />
            <GradientStop Offset="1.0" Color="#00F2FF" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InsetGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0.0" Color="#12141A" />
            <GradientStop Offset="0.5" Color="#1E222D" />
            <GradientStop Offset="1.0" Color="#2A2E39" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="InsetCornerGlow" Center="1,1" GradientOrigin="1,1" RadiusX="0.6" RadiusY="0.6">
            <GradientStop Offset="0" Color="#A0E3" />

            <GradientStop Offset="0.4" Color="#30A0FFE3" />

            <GradientStop Offset="0.9" Color="#FF232732" />

            <GradientStop Offset="1" Color="#FF232732" />
        </RadialGradientBrush>
    </Application.Resources>
</Application>
