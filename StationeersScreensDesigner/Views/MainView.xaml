<Window
    x:Class="StationeersScreensDesigner.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:CodeParagon.Behaviors;assembly=CodeParagon.Behaviors"
    xmlns:bh="clr-namespace:StationeersScreensDesigner.Behaviours"
    xmlns:controls="clr-namespace:StationeersScreensDesigner.Controls"
    xmlns:conv="clr-namespace:StationeersScreensDesigner.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:StationeersScreensDesigner.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mod="clr-namespace:StationeersScreensDesigner.Models"
    xmlns:sel="clr-namespace:StationeersScreensDesigner.Selectors"
    xmlns:vm="clr-namespace:StationeersScreensDesigner.ViewModels"
    Title="Designer"
    Width="1500"
    Height="800"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    Background="{StaticResource BackgroundMain}"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="F2" Command="{Binding ChangeScreenNameCommand}" />
        <KeyBinding
            Key="D"
            Command="{Binding CurrentScreen.DuplicateSelectedCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>
    <Window.Resources>
        <ResourceDictionary>

            <Style x:Key="BrowserTabStyle" TargetType="ListBoxItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                x:Name="TabBorder"
                                Margin="2,0"
                                Padding="15,5"
                                Background="#1A1A1A"
                                BorderBrush="{StaticResource SeparatorBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseEnter">
                                        <i:ChangePropertyAction
                                            PropertyName="HoveredScreen"
                                            TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Value="{Binding}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:ChangePropertyAction
                                            PropertyName="HoveredScreen"
                                            TargetObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Value="{x:Null}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />


                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#2A2A2A" />
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="White" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#333" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <SolidColorBrush x:Key="blackish" Color="#1e1e24" />

            <conv:SubtypeToStringConverter x:Key="SubtypeToString" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:MultiValueConverter x:Key="MultiBinding" />
            <conv:MouseWheelZoomConverter x:Key="MouseWheelZoom" />
            <conv:DimensionToPixelsConverter x:Key="DimensionToPixelsConverter" />
            <Border
                x:Key="MyFollowerVisual"
                Width="60"
                Height="60"
                Background="#804A90E2"
                BorderBrush="White"
                BorderThickness="2"
                CornerRadius="30"
                IsHitTestVisible="False">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="🚀" />
            </Border>

            <Style x:Key="ToolboxGroup" TargetType="Expander">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="IsExpanded" Value="False" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="DemiBold" />
                <Setter Property="HeaderTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding}" />
                                <Rectangle
                                    Height="1"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Stretch"
                                    Fill="White" />
                            </StackPanel>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/CustomIcons.xaml" />
                <ResourceDictionary Source="/Themes/Styles.xaml" />
                <ResourceDictionary Source="/Themes/PropertyEditor.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <i:Interaction.Triggers />

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="520" />
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!--  Top Section  -->
        <Border
            Grid.ColumnSpan="100"
            Background="{StaticResource PanelGradient}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="1">
            <Grid>
                <Rectangle
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Fill="#BA1BBB"
                    Opacity="0.1">
                    <Rectangle.Effect>
                        <BlurEffect
                            KernelType="Box"
                            Radius="70"
                            RenderingBias="Quality" />
                    </Rectangle.Effect>

                </Rectangle>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <!--  Save Button  -->
                    <StackPanel>
                        <Button
                            Width="25"
                            Height="25"
                            BorderThickness="0"
                            Command="{Binding SaveProjectCommand}"
                            Cursor="Hand"
                            Focusable="False">
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource IconSaveDrawing}" />
                            </Button.Background>
                        </Button>
                        <TextBlock
                            FontFamily="Simplex"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimary}"
                            Text="SAVE" />
                    </StackPanel>

                    <!--  spacing  -->
                    <Border Width="15" />

                    <!--  Open Button  -->
                    <StackPanel>
                        <Button
                            Width="25"
                            Height="25"
                            BorderThickness="0"
                            Command="{Binding LoadProjectCommand}"
                            Cursor="Hand"
                            Focusable="False">
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource IconSaveDrawing}" />
                            </Button.Background>
                        </Button>
                        <TextBlock
                            FontFamily="Simplex"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimary}"
                            Text="OPEN" />
                    </StackPanel>
                    <!--  Spacing  -->
                    <Border Width="15" />

                    <!--  Close Button  -->
                    <StackPanel>
                        <Button
                            Width="25"
                            Height="25"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False">
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource CloseDrawing}" />
                            </Button.Background>
                            <i:Interaction.Behaviors>
                                <beh:CloseWindowOnClickBehavior />
                            </i:Interaction.Behaviors>
                        </Button>
                        <TextBlock
                            FontFamily="Simplex"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Close" />
                    </StackPanel>

                    <Border Width="15" />

                    <!--  Copy Button  -->
                    <StackPanel>
                        <Button
                            Width="25"
                            Height="25"
                            BorderThickness="0"
                            Command="{Binding CopyCodeCommand}"
                            Cursor="Hand"
                            Focusable="False">
                            <Button.Background>
                                <ImageBrush ImageSource="{StaticResource CopyDrawing}" />
                            </Button.Background>
                        </Button>
                        <TextBlock
                            FontFamily="Simplex"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Copy&#x0a;Code" />
                    </StackPanel>

                </StackPanel>


            </Grid>


        </Border>
        <!--  ToolBox with UI elements  -->
        <Border
            Grid.Row="2"
            Grid.Column="1"
            Background="{StaticResource BackgroundPanel}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel>
                <TextBlock
                    FontFamily="Complex"
                    Foreground="{StaticResource TextPrimary}"
                    Opacity="0.6"
                    Text="ELEMENT LIBRARY">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="3"
                            Direction="300"
                            Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>
                <Separator Background="{StaticResource SeparatorBrush}" />
                <ItemsControl ItemsSource="{Binding AvailableElements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="mod:LuaUIElement">
                            <DataTemplate.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Light" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontSize" Value="16" />
                                </Style>
                            </DataTemplate.Resources>
                            <StackPanel>
                                <Border
                                    Margin="10,10,0,0"
                                    HorizontalAlignment="Left"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="2">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.StartDragCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <i:InvokeCommandAction.CommandParameter>
                                                    <MultiBinding Converter="{StaticResource MultiBinding}">
                                                        <Binding Path="." />
                                                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" />
                                                    </MultiBinding>
                                                </i:InvokeCommandAction.CommandParameter>
                                            </i:InvokeCommandAction>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Converter={StaticResource SubtypeToString}, StringFormat='◈ {0}'}" />
                                    </StackPanel>
                                </Border>
                                <Separator />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!--  Designer View  -->
        <Border
            Grid.Row="2"
            Grid.Column="2"
            Width="500"
            HorizontalAlignment="Right"
            Background="{StaticResource BackgroundPanel}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontFamily="Complex"
                    Foreground="{StaticResource TextPrimary}"
                    Opacity="0.6"
                    Text="LIVE CANVAS">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="3"
                            Direction="300"
                            Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    FontFamily="Complex"
                    Foreground="{StaticResource TextPrimary}"
                    Opacity="0.6"
                    Text="{Binding CurrentScreen.ZoomLevel, StringFormat='ZOOM LEVEL: {0:0%}'}">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="3"
                            Direction="300"
                            Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>

                <Separator Grid.Row="1" Background="{StaticResource SeparatorBrush}" />

                <Grid Grid.Row="2">
                    <!--<Border Background="{StaticResource BlueprintGridThick}" Panel.ZIndex="2" IsHitTestVisible="False"/>
                    <Border Background="{StaticResource BlueprintGridThin}" Panel.ZIndex="2" IsHitTestVisible="False"/>-->

                    <ScrollViewer
                        Panel.ZIndex="3"
                        Background="Transparent"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource StationeersScrollBar}" TargetType="ScrollBar" />
                        </ScrollViewer.Resources>
                        <i:Interaction.Behaviors>
                            <bh:DesignerScrollBehaviour ZoomCommand="{Binding CurrentScreen.ZoomCommand}" />
                        </i:Interaction.Behaviors>
                        <ItemsControl
                            Width="2000"
                            Height="2000"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ItemsSource="{Binding CurrentScreen.CanvasElements}">

                            <ItemsControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding CurrentScreen.ZoomLevel}" ScaleY="{Binding CurrentScreen.ZoomLevel}" />
                            </ItemsControl.LayoutTransform>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas AllowDrop="True" Background="{StaticResource MasterBlueprintGrid}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Drop">
                                                <i:InvokeCommandAction Command="{Binding StopDragCommand}" PassEventArgsToCommand="True" />
                                            </i:EventTrigger>
                                            <i:EventTrigger EventName="MouseDown">
                                                <i:InvokeCommandAction Command="{Binding DeselectElementsCommand}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Canvas>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource DimensionToPixelsConverter}">
                                                <Binding Path="X" />
                                                <Binding Path="Unit" />
                                                <!--  Look up to find the Screen's TargetWidth  -->
                                                <Binding Path="DataContext.CurrentScreen.TargetWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.Top">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource DimensionToPixelsConverter}">
                                                <Binding Path="Y" />
                                                <Binding Path="Unit" />
                                                <!--  Look up to find the Screen's TargetHeight  -->
                                                <Binding Path="DataContext.CurrentScreen.TargetHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.Resources>
                                <ResourceDictionary>
                                    <ResourceDictionary.MergedDictionaries>
                                        <ResourceDictionary Source="/Themes/DisplayLuaElements.xaml" />
                                    </ResourceDictionary.MergedDictionaries>
                                </ResourceDictionary>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!--  Properties  -->
        <Border
            Grid.Row="2"
            Grid.Column="3"
            Width="300"
            HorizontalAlignment="Right"
            Background="{StaticResource BackgroundPanel}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <StackPanel>
                <TextBlock
                    FontFamily="Complex"
                    Foreground="{StaticResource TextPrimary}"
                    Opacity="0.6"
                    Text="PROPERTIES">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="3"
                            Direction="300"
                            Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>
                <Separator Background="{StaticResource SeparatorBrush}" />
                <ScrollViewer Height="600" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style BasedOn="{StaticResource StationeersScrollBar2}" TargetType="ScrollBar" />
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding ActiveProperties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,10">
                                    <TextBlock
                                        FontSize="16"
                                        Foreground="White"
                                        Opacity="0.8"
                                        Text="{Binding GroupName}" />

                                    <ItemsControl ItemsSource="{Binding Properties}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="140" Margin="2">
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="White"
                                                        Opacity="0.8"
                                                        Text="{Binding DisplayName}" />
                                                    <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource MyPropertySelector}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!--  Lua Viewer/Hierarchy Viewer  -->
        <Border
            Grid.Row="2"
            Grid.Column="4"
            Width="370"
            HorizontalAlignment="Right"
            Background="{StaticResource BackgroundPanel}"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="8">
            <Grid Width="370">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="9*" />
                    <ColumnDefinition Width="361*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="5,2,5,2"
                    FontFamily="Complex"
                    Foreground="{StaticResource TextPrimary}"
                    Opacity="0.6"
                    Text="HIERARCHY VIEWER">
                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="3"
                            Direction="300"
                            Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>

                <Separator
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,2,0,2"
                    Background="{StaticResource SeparatorBrush}" />
                <!--
                <ScrollViewer
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="2"
                    Width="365"
                    Height="605"
                    Margin="0,5,0,-11"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#0F111A"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style BasedOn="{StaticResource StationeersScrollBar2}" TargetType="ScrollBar" />
                    </ScrollViewer.Resources>

                    <Grid Margin="5" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            FontFamily="Consolas"
                            FontSize="13"
                            Foreground="#444"
                            LineHeight="20"
                            Text="{Binding LineNumbers}"
                            TextAlignment="Right" />

                        <TextBox
                            Grid.Column="1"
                            AcceptsReturn="True"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            FontSize="13"
                            Foreground="#A6ACCD"
                            IsReadOnly="True"
                            Text="{Binding GeneratedLuaCode, Mode=OneWay}"
                            TextWrapping="NoWrap" />
                    </Grid>
                </ScrollViewer>
                -->
                <ScrollViewer
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="2"
                    Width="365"
                    Height="580"
                    Margin="0,5,0,-11"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#0F111A"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style BasedOn="{StaticResource StationeersScrollBar2}" TargetType="ScrollBar" />
                    </ScrollViewer.Resources>

                    <TreeView Background="Transparent">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontFamily" Value="Simplex" />
                            </Style>
                        </TreeView.Resources>
                        <TreeViewItem
                            Foreground="Yellow"
                            Header="Display       --Coming Soon !--"
                            IsExpanded="True">
                            <TreeViewItem Header="VisualElement1" />
                            <TreeViewItem Header="VisualElement2" />
                            <TreeViewItem Header="Grid1">
                                <TreeViewItem Header="VisualElement3" />
                                <TreeViewItem Header="VisualElement4" />
                            </TreeViewItem>
                            <TreeViewItem Header="VisualElement5" />
                            <TreeViewItem Header="FlexBox1">
                                <TreeViewItem Header="Grid1">
                                    <TreeViewItem Header="VisualElement6" />
                                    <TreeViewItem Header="VisualElement7" />
                                </TreeViewItem>
                            </TreeViewItem>
                        </TreeViewItem>
                    </TreeView>
                </ScrollViewer>
                <StackPanel
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontFamily="Complex"
                        Foreground="White"
                        Text="Display Target Size: " />
                    <controls:SizeTextBox
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        ValueHeight="{Binding CurrentScreen.TargetHeight}"
                        ValueWidth="{Binding CurrentScreen.TargetWidth}" />
                </StackPanel>

            </Grid>
        </Border>

        <!--  Bottom Section  -->
        <Border
            Grid.Row="4"
            Grid.Column="1"
            Grid.ColumnSpan="4"
            Background="#111"
            BorderBrush="{StaticResource SeparatorBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">

                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource BrowserTabStyle}"
                    ItemsSource="{Binding Screens}"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    SelectedItem="{Binding CurrentScreen}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="White"
                                    Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBox
                                    MinWidth="50"
                                    Background="#444"
                                    BorderBrush="#BA1BBB"
                                    BorderThickness="1"
                                    FontSize="12"
                                    Foreground="White"
                                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>

                                    <i:Interaction.Behaviors>
                                        <bh:TextBoxRenameBehavior CancelCommand="{Binding CancelEditCommand}" CommitCommand="{Binding CommitEditCommand}" />
                                    </i:Interaction.Behaviors>
                                </TextBox>
                            </Grid>
                        </DataTemplate>

                    </ListBox.ItemTemplate>
                </ListBox>

                <Button
                    Width="30"
                    Height="30"
                    Margin="5,0,0,5"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding AddScreenCommand}"
                    Content="+"
                    Cursor="Hand"
                    FontSize="18"
                    Foreground="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#BA1BBB" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
        <!--  Accent  -->
        <Grid
            Grid.RowSpan="1000"
            Grid.ColumnSpan="1000"
            IsHitTestVisible="False">
            <Grid.CacheMode>
                <BitmapCache
                    EnableClearType="True"
                    RenderAtScale="1"
                    SnapsToDevicePixels="True" />
            </Grid.CacheMode>
            <Ellipse
                Grid.Row="2"
                Grid.RowSpan="10"
                Grid.Column="3"
                Grid.ColumnSpan="10"
                Width="600"
                Height="600"
                Margin="0,0,270,-250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Fill="#FF007F"
                Opacity="0.03">
                <Ellipse.Effect>
